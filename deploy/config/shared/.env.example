# ==========================================
# PHD STUDIO - VARIÁVEIS DE AMBIENTE
# ==========================================
# Copie este arquivo para deploy/config/shared/.env e preencha os valores
# cp deploy/config/shared/.env.example deploy/config/shared/.env

# ==========================================
# VARIÁVEIS DO FRONTEND (Build Time)
# ==========================================

# Gemini AI (para chat)
GEMINI_API_KEY=

# EmailJS (para formulários)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_RECIPIENT_EMAIL=

# Webhook do Chat (n8n)
VITE_CHAT_WEBHOOK_URL=
VITE_CHAT_AUTH_TOKEN=

# URL da API (produção)
VITE_API_URL=https://phdstudio.com.br/api

# Instagram Feed (Facebook Graph API)
VITE_INSTAGRAM_API_URL=https://phdstudio.com.br/api/instagram

# ==========================================
# VARIÁVEIS DO BACKEND (Runtime)
# ==========================================

# PostgreSQL (CRM + Produtos)
CRM_DB_HOST=localhost
CRM_DB_PORT=5432
CRM_DB_USER=phd_crm_user
CRM_DB_PASSWORD=
CRM_DB_NAME=phd_crm

# Base para imagens dos produtos (opcional)
PRODUCTS_MEDIA_BASE_URL=https://phdstudio.com.br

# API Key (gerar uma chave segura)
PHD_API_KEY=

# JWT Secrets (GERAR VALORES ÚNICOS E SEGUROS!)
JWT_SECRET=
JWT_REFRESH_SECRET=

# CORS
ALLOWED_ORIGINS=https://phdstudio.com.br,http://phdstudio.com.br,http://localhost:8080,http://localhost:3000,http://localhost:5173

# Porta da API
API_PORT=3001

# Ambiente
NODE_ENV=production

# Instagram Access Token (Facebook Graph API)
# Obtenha um token de longa duração em: https://developers.facebook.com/tools/explorer/
# Token deve ter permissões: instagram_basic, pages_read_engagement, pages_show_list
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=17841403453191047
INSTAGRAM_API_VERSION=v22.0

# ==========================================
# RESILIÊNCIA — Blog (backend)
# ==========================================
# Timeout (ms) por tentativa de chamada ao upstream do blog
BLOG_FETCH_TIMEOUT_MS=5000
# Número de retries para erros transitórios (TIMEOUT, DNS, NETWORK)
BLOG_FETCH_RETRIES=1
# Espera base entre retries (ms); cada retry multiplica por attempt index
BLOG_FETCH_BACKOFF_MS=1000
# TTL do cache em memória do blog (ms) — padrão 10 min
BLOG_CACHE_TTL=600000

# ==========================================
# RESILIÊNCIA — Instagram (backend)
# ==========================================
# Timeout (ms) por tentativa de chamada à Graph API
INSTAGRAM_FETCH_TIMEOUT_MS=5000
# Número de retries para erros transitórios
INSTAGRAM_FETCH_RETRIES=1
# Espera base entre retries (ms)
INSTAGRAM_FETCH_BACKOFF_MS=1000
# TTL do cache em memória do Instagram (ms) — padrão 5 min
INSTAGRAM_CACHE_TTL=300000
